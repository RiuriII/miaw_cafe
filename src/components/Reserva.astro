---
// src/components/Reserva.astro
import ReservaForm from "./ReservaForm";
---

<section id="reserva" aria-label="Reservar mesa no Miaw Café" class="reserva">
	<!-- Large decorative background text -->
	<div class="reserva__bg-text" aria-hidden="true">MIAW</div>

	<div class="reserva__wrap">
		<span class="reserva__tag text-mono">Reserve sua experiência</span>

		<h2 class="reserva__heading text-display">
			Venha<br />Nos Visitar
		</h2>

		<p class="reserva__subtitle">
			<em>
				Reserve sua mesa e garanta um momento especial com café artesanal e muita fofura felina.
				Vagas limitadas para proporcionar a melhor experiência.
			</em>
		</p>

		<!-- React form with Framer Motion animations -->
		<ReservaForm client:visible />

		<!-- Divider -->
		<div class="reserva__divider" aria-hidden="true">
			<div class="reserva__divider-line"></div>
			<span class="reserva__divider-text">ou entre em contato</span>
			<div class="reserva__divider-line"></div>
		</div>

		<!-- Contact info row -->
		<div class="reserva__info" role="list" aria-label="Informações de contato">
			<div class="reserva__info-item" role="listitem">
				<span aria-hidden="true">📞</span>
				<a href="tel:+5511999998888" aria-label="Telefone: 11 9 9999-8888">(11) 9 9999-8888</a>
			</div>
			<div class="reserva__info-item" role="listitem">
				<span aria-hidden="true">📍</span>
				<span>Rua Augusta, 1420 — Pinheiros</span>
			</div>
			<div class="reserva__info-item" role="listitem">
				<span aria-hidden="true">🕙</span>
				<span>Ter–Dom, 10h–20h</span>
			</div>
		</div>
	</div>
</section>

<style>
	.reserva {
		background: var(--color-lime);
		padding: var(--section-padding-y) var(--section-padding-x);
		position: relative;
		border-top: 3px solid var(--color-ink);
		border-bottom: 3px solid var(--color-ink);
		overflow: hidden;
	}

	.reserva__bg-text {
		position: absolute;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(6rem, 15vw, 24rem);
		text-transform: uppercase;
		letter-spacing: -0.05em;
		color: rgba(26, 21, 16, 0.04);
		bottom: -60px;
		left: -20px;
		line-height: 1;
		user-select: none;
		pointer-events: none;
		white-space: nowrap;
	}

	.reserva__wrap {
		max-width: 780px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 2;
	}

	.reserva__tag {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		letter-spacing: 0.16em;
		color: var(--color-rust);
		margin-bottom: 24px;
		display: block;
	}

	.reserva__heading {
		font-size: clamp(3.5rem, 8vw, 6.5rem);
		color: var(--color-ink);
		line-height: 0.88;
		margin-bottom: 24px;
	}

	.reserva__subtitle {
		font-family: var(--font-body);
		font-style: italic;
		font-size: 1.2rem;
		color: rgba(26, 21, 16, 0.58);
		margin-bottom: 48px;
		line-height: 1.65;
		max-width: 580px;
		margin-left: auto;
		margin-right: auto;
	}

	/* ── Divider ──────────────────────────────────── */
	.reserva__divider {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-top: 48px;
		margin-bottom: 20px;
	}

	.reserva__divider-line {
		height: 1px;
		width: 60px;
		background: rgba(26, 21, 16, 0.2);
	}

	.reserva__divider-text {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #241e16b5;
	}

	/* ── Info row ─────────────────────────────────── */
	.reserva__info {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 32px;
		flex-wrap: wrap;
	}

	.reserva__info-item {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #241e16b5;
	}

	.reserva__info-item a {
		color: inherit;
		text-decoration: none;
		transition: color 0.15s;
	}

	.reserva__info-item a:hover {
		color: var(--color-ink);
	}

	/* ── Responsive ───────────────────────────────── */
	@media (max-width: 768px) {
		.reserva__info {
			flex-direction: column;
			gap: 12px;
		}
		.reserva__bg-text {
			font-size: 8rem;
		}
	}

	@media (max-width: 400px) {
		.reserva__heading {
			font-size: clamp(2.5rem, 10vw, 4rem);
		}
</style>
