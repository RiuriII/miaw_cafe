---
// src/components/Testimonials.astro
import { TESTIMONIALS } from '../data';
---

<section id="depoimentos" aria-label="Depoimentos de clientes" class="testimonials">

  <!-- Section header -->
  <div class="sec-header">
    <div>
      <p class="section-label">O que dizem</p>
      <h2 class="testimonials__heading text-display">
        Vozes<br>Felinas
      </h2>
    </div>
    <div class="testimonials__rating" aria-label="Avaliação média: 4.9 de 5 com 1240 avaliações">
      <div class="testimonials__rating-number">4.9</div>
      <div class="testimonials__rating-count">1.240 avaliações</div>
    </div>
  </div>

  <!-- Cards grid -->
  <div class="testimonials__grid" role="list" aria-label="Depoimentos">
    {TESTIMONIALS.map((testimonial, i) => (
      <article
        class={`testimonials__card ${i === 1 ? 'testimonials__card--featured' : ''}`}
        role="listitem"
        data-reveal
      >
        
        <!-- Stars -->
        <div
          class="testimonials__stars"
          aria-label={`${testimonial.rating} estrelas`}
          role="img"
        >
          {'★'.repeat(testimonial.rating)}
        </div>

        <!-- Opening quote mark -->
        <span class="testimonials__quote-mark" aria-hidden="true">"</span>

        <!-- Review text -->
        <blockquote class="testimonials__text">
          {testimonial.text}
        </blockquote>

        <!-- Author -->
        <div class="testimonials__meta">
          <div
            class="testimonials__avatar"
            aria-hidden="true"
            aria-label={`Foto de ${testimonial.name}`}
          >
            {testimonial.avatar}
          </div>
          <div>
            <p class="testimonials__name">{testimonial.name}</p>
            <p class="testimonials__location">{testimonial.location}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .testimonials {
    background: var(--color-parchment);
    padding: var(--section-padding-y) var(--section-padding-x);
    position: relative;
  }

  .testimonials__heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .testimonials__rating {
    text-align: right;
  }

  .testimonials__rating-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2.5rem;
    color: var(--color-terra);
    line-height: 1;
  }

  .testimonials__rating-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-sand);
    margin-top: 4px;
  }

  /* ── Grid ─────────────────────────────────────── */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  /* ── Card ─────────────────────────────────────── */
  .testimonials__card {
    position: relative;
    width: 100%;
    max-width: 460px;
    background: var(--color-white);
    border: 3px solid var(--color-ink);
    padding: 32px;
    cursor: default;
    box-shadow:  6px 6px 0px 2px var(--color-ink);
    transition: 
      opacity 0.5s ease,
		  transform 0.3s ease-out,
      box-shadow 0.2s ease;
  }
  
  .testimonials__card:hover {
    box-shadow:  7px 10px 0px 3px var(--color-ink);
    transform: translateY(-15px);
  }

  /* Featured (middle) card */
  .testimonials__card--featured {
    background: var(--color-terra);
    color: var(--color-white);
    transform: translateY(-20px);
    box-shadow:  7px 7px 0px 2px var(--color-ink)
  } 

  .testimonials__card--featured:hover {
    transform: translateY(-25px);
    box-shadow:  10px 10px 0px 3px var(--color-ink);
  }


  .testimonials__stars {
    font-size: 0.7rem;
    color: var(--color-terra);
    margin-bottom: 18px;
    letter-spacing: 3px;
  }

  .testimonials__card--featured .testimonials__stars {
    color: rgba(250, 247, 240, 0.55);
  }

  .testimonials__quote-mark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 5rem;
    line-height: 0.5;
    color: var(--color-terra);
    margin-bottom: 18px;
    display: block;
  }

  .testimonials__card--featured .testimonials__quote-mark {
    color: rgba(250, 247, 240, 0.18);
  }

  .testimonials__text {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.72;
    color: rgba(26, 21, 16, 0.78);
    margin-bottom: 24px;
  }

  .testimonials__card--featured .testimonials__text {
    color: rgba(250, 247, 240, 0.88);
  }

  .testimonials__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonials__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-parchment);
    border: 2px solid var(--color-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .testimonials__card--featured .testimonials__avatar {
    background: rgba(250, 247, 240, 0.18);
    border-color: rgba(250, 247, 240, 0.28);
  }

  .testimonials__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    margin-bottom: 2px;
    color: var(--color-ink);
  }

  .testimonials__card--featured .testimonials__name {
    color: var(--color-white);
  }

  .testimonials__location {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sand);
  }

  .testimonials__card--featured .testimonials__location {
    color: rgba(250, 247, 240, 0.48);
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 950px) {
    .testimonials__grid { grid-template-columns: 1fr; }
    .testimonials__card--featured { transform: none; }
  }
</style>
